# CDK build output
infra/cdk.out/

# FastF1 raw cache (regenerated by collect_f1_data.py)
data/raw/

# Processed feature files (regenerated by collect_f1_data.py)
data/processed/

# Trained model artifacts (stored in S3; retrain with training scripts)
data/models/

# Lambda bundled packages (install via: pip install --platform manylinux2014_x86_64 --target lambda/)
lambda/*
!lambda/inference/

# Python
__pycache__/
*.py[cod]
*.pyc
.venv/
venv/
*.egg-info/
dist/
build/

# Environment / secrets
.env
*.env
.env.*

# OS
.DS_Store
Thumbs.db
